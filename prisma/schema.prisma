generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Landlord
  Marketer
  Broker
}

model UserProfile {
  id          String   @id @default(uuid())
  firebaseId  String   @unique
  email       String
  role        Role
  phone       String?
  avatarUrl   String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
